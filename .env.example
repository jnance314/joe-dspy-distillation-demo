# API keys -- add the ones for the providers you want to use.
# LiteLLM (used by DSPy) auto-detects these environment variables.

# Google Gemini (required for default models)
GEMINI_API_KEY=your-key-here

# OpenAI (required if you select OpenAI models)
OPENAI_API_KEY=your-key-here

# Anthropic (required if you select Anthropic models)
ANTHROPIC_API_KEY=your-key-here
